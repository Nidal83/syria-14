# Syria Homes Nest — Environment variables
# Copy this file to `.env` and fill in your local Supabase project details.
# Never commit `.env`. Only `.env.example` should be in version control.

# Supabase
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-public-key>"

# Optional — used by some Supabase tooling
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# App
VITE_APP_NAME="Syria Homes Nest"
VITE_APP_URL="http://localhost:8080"
