# Syria Homes Nest — Environment variables
# Copy this file to `.env` and fill in your local Supabase project details.
# Never commit `.env`. Only `.env.example` should be in version control.

# Supabase
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-public-key>"

# Optional — used by some Supabase tooling
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# App
VITE_APP_NAME="Syria Homes Nest"
VITE_APP_URL="http://localhost:8080"

# Sentry (optional — leave empty to disable)
# Used at runtime to send errors. Get the DSN from Sentry project settings.
VITE_SENTRY_DSN=""
# 'production' on the live site, 'preview' on Vercel preview deploys,
# 'development' locally. Optional; defaults to import.meta.env.PROD.
VITE_APP_ENV=""

# Sentry source-map upload (build-time only — never exposed to the browser).
# Set these in Vercel project settings, NOT in VITE_*. They must NOT have
# the VITE_ prefix or they will leak into the bundle.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
